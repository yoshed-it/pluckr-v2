{
  "expo": {
    "name": "Pluckr",
    "slug": "pluckr-v2",
    "scheme": "pluckr",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pluckr.prototype",
      "infoPlist": {
        "NSCameraUsageDescription": "Pluckr uses the camera to capture treatment photos for clinical charting."
      }
    },
    "android": {
      "package": "com.pluckr.prototype"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
