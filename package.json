{
  "name": "pluckr-v2",
  "version": "0.1.0",
  "private": true,
  "main": "./index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @pluckr/web",
    "build:web": "npm run build --workspace @pluckr/web",
    "start:mobile": "npm run start --workspace @pluckr/mobile",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "playwright": "^1.61.0"
  }
}
